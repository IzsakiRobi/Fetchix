{
  "manifest_version": 2,
  "name": "Send to Fetchix",
  "version": "1.0",
  "description": "Send links directly to the Fetchix download manager via the context menu.",
  "permissions": [
    "contextMenus"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "128": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fetchix-extension@IzsakiRobi.com",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}

